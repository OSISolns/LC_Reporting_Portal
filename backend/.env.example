# ==============================================
# Legacy Clinics Lumina Portal — Backend ENV
# Copy this file to .env and fill in your values
# ==============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your-very-strong-secret-key-change-this-in-production
JWT_EXPIRES_IN=8h

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lc_reporting
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── Imaging (Radiology) Portal integrations ────────────────────────────────
# Field-level encryption key (also used across the app). Set in production.
DB_ENCRYPTION_KEY=change-this-encryption-key-in-production
# WHO ICD-11 (diagnosis coding)
ICD11_CLIENT_ID=
ICD11_CLIENT_SECRET=
# LOINC (exam-type coding) — free account at https://loinc.org
LOINC_USER=
LOINC_PASSWORD=
# SNOMED CT (findings coding) — Snowstorm FHIR server
SNOWSTORM_FHIR_URL=https://snowstorm.ihtsdotools.org/fhir
# DICOM PACS (DICOMweb: QIDO/WADO/STOW-RS), e.g. Orthanc
ORTHANC_DICOMWEB_URL=
ORTHANC_USER=
ORTHANC_PASSWORD=
