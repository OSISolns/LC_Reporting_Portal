# 🏥 Legacy Clinics Lumina Portal - Vercel Environment Variables

# ── Backend Configuration ─────────────────────────────────────────────────────────
# These must be set in your Vercel Project Settings -> Environment Variables

# [Database]
# Copy these from your Turso Dashboard (https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-very-long-auth-token-here

# [Security]
# A strong random string for JWT signing
JWT_SECRET=your_super_secret_key_here

# [Insights - Google Gemini]
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [ICD-11 API - WHO]
# Register at https://icd.who.int/icdapi to get your Client ID and Secret
ICD11_CLIENT_ID=your_icd11_client_id_here
ICD11_CLIENT_SECRET=your_icd11_client_secret_here

# ── Imaging (Radiology) Portal integrations ──────────────────────────────────────
# [LOINC - exam type coding] Free account at https://loinc.org (FHIR terminology server)
LOINC_USER=your_loinc_username_here
LOINC_PASSWORD=your_loinc_password_here
# [SNOMED CT - findings coding] Public Snowstorm FHIR server (or your licensed instance)
SNOWSTORM_FHIR_URL=https://snowstorm.ihtsdotools.org/fhir
# [DICOM - images] DICOMweb (QIDO/WADO/STOW-RS) endpoint of your PACS, e.g. Orthanc
ORTHANC_DICOMWEB_URL=http://localhost:8042/dicom-web
ORTHANC_USER=your_orthanc_username_here
ORTHANC_PASSWORD=your_orthanc_password_here
# [HL7 FHIR] Base URL this server advertises in FHIR resource references
FHIR_BASE_URL=https://your-app-name.vercel.app/api/imaging/fhir

# [Frontend]
# Your production URL (e.g., https://lc-reporting-portal.vercel.app)
# This is used for CORS and PDF image resolution
FRONTEND_URL=https://your-app-name.vercel.app

# ── Node.js Version ──────────────────────────────────────────────────────────────
# Ensure your Vercel project is set to Node.js 18.x or 20.x
NODE_ENV=production
